{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/seo-audit.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
